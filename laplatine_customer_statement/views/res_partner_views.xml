<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_partner_form_laplatine_customer_statement" model="ir.ui.view">
        <field name="name">res.partner.form.laplatine.customer.statement</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="%(laplatine_customer_statement.action_laplatine_customer_statement_wizard)d"
                    type="action"
                    string="État de facturation"
                    class="oe_stat_button"
                    icon="fa-file-excel-o"
                    groups="account.group_account_invoice"
                    invisible="customer_rank == 0"
                />
            </xpath>
        </field>
    </record>
</odoo>
