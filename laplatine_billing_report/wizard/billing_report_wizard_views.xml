<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_laplatine_billing_report_wizard_form" model="ir.ui.view">
        <field name="name">laplatine.billing.report.wizard.form</field>
        <field name="model">laplatine.billing.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Rapport de facturation">
                <group>
                    <field name="date_from"/>
                    <field name="date_to"/>
                </group>
                <footer>
                    <button
                        name="action_generate_xlsx"
                        type="object"
                        string="Générer le rapport Excel"
                        class="btn-primary"
                    />
                    <button special="cancel" string="Annuler" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_laplatine_billing_report_wizard" model="ir.actions.act_window">
        <field name="name">Rapport de facturation</field>
        <field name="res_model">laplatine.billing.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
