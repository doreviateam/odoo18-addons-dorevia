<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template
        id="external_layout_standard_laplatine_logo_size"
        inherit_id="web.external_layout_standard"
    >
        <xpath
            expr="//img[contains(concat(' ', normalize-space(@class), ' '), ' o_company_logo_small ')]"
            position="attributes"
        >
            <attribute name="style">max-height: 120px; max-width: 320px; width: auto;</attribute>
        </xpath>
    </template>

