<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_procurement_control_user" model="res.groups">
        <field name="name">Pilotage approvisionnements / Consultation</field>
        <field name="category_id" ref="base.module_category_inventory_inventory"/>
        <field name="implied_ids" eval="[(4, ref('stock.group_stock_user'))]"/>
    </record>

    <record id="group_procurement_control_manager" model="res.groups">
        <field name="name">Pilotage approvisionnements / Actualisation</field>
        <field name="category_id" ref="base.module_category_inventory_inventory"/>
        <field name="implied_ids" eval="[(4, ref('group_procurement_control_user'))]"/>
    </record>

    <record id="group_procurement_control_config" model="res.groups">
        <field name="name">Pilotage approvisionnements / Paramétrage</field>
        <field name="category_id" ref="base.module_category_inventory_inventory"/>
        <field name="implied_ids" eval="[(4, ref('group_procurement_control_manager'))]"/>
    </record>
</odoo>
