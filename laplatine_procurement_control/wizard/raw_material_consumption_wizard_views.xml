<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="raw_material_consumption_wizard_view_form" model="ir.ui.view">
        <field name="name">laplatine.raw.material.consumption.wizard.form</field>
        <field name="model">laplatine.raw.material.consumption.wizard</field>
        <field name="arch" type="xml">
            <form string="Consommation matière première">
                <group>
                    <field name="allowed_location_ids" invisible="1"/>
                    <field name="location_is_auto" invisible="1"/>
                    <field name="product_id" options="{'no_create': True}"/>
                    <field name="location_id" readonly="location_is_auto" force_save="1"/>
                    <field name="qty_available_kg"/>
                    <field name="qty_consumed_kg"/>
                </group>
                <footer>
                    <button
                        name="action_register_consumption"
                        type="object"
                        string="Enregistrer la consommation"
                        class="btn-primary"
                    />
                    <button special="cancel" string="Annuler" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="raw_material_consumption_wizard_action" model="ir.actions.act_window">
        <field name="name">Consommation matière première</field>
        <field name="res_model">laplatine.raw.material.consumption.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
