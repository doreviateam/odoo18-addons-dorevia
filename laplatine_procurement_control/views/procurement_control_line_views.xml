<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="procurement_control_line_view_tree" model="ir.ui.view">
        <field name="name">laplatine.procurement.control.line.tree</field>
        <field name="model">laplatine.procurement.control.line</field>
        <field name="arch" type="xml">
            <list string="Pilotage approvisionnements" create="false" edit="false">
                <field name="product_id"/>
                <field name="risk_status"/>
                <field name="risk_reason"/>
                <field name="action_recommended"/>
                <field name="last_refresh"/>
                <field name="refreshed_by_id"/>
            </list>
        </field>
    </record>

    <record id="procurement_control_line_view_form" model="ir.ui.view">
        <field name="name">laplatine.procurement.control.line.form</field>
        <field name="model">laplatine.procurement.control.line</field>
        <field name="arch" type="xml">
            <form string="Ligne cockpit approvisionnements" create="false" edit="false">
                <sheet>
                    <group>
                        <field name="product_id"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                        <field name="risk_status"/>
                        <field name="risk_reason"/>
                        <field name="action_recommended"/>
                        <field name="last_refresh"/>
                        <field name="refreshed_by_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="procurement_control_line_action" model="ir.actions.act_window">
        <field name="name">Pilotage approvisionnements</field>
        <field name="res_model">laplatine.procurement.control.line</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
