<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- BUG-CONS-MP-001: le menu Configuration Stock exige stock.group_stock_manager ;
         le profil Consultation doit pouvoir y accéder pour le chemin UI documenté. -->
    <record id="stock.menu_stock_config_settings" model="ir.ui.menu">
        <field
            name="groups_id"
            eval="[(4, ref('laplatine_procurement_control.group_procurement_control_user'))]"
        />
    </record>

    <menuitem
        id="menu_laplatine_root"
        name="La Platine"
        parent="stock.menu_stock_root"
        sequence="15"
        groups="laplatine_procurement_control.group_raw_material_consumption_user"
    />
    <menuitem
        id="menu_raw_material_consumption"
        name="Consommation matière première"
        parent="menu_laplatine_root"
        action="raw_material_consumption_wizard_action"
        sequence="10"
    />
    <menuitem
        id="menu_raw_material_stock_update"
        name="Mise à jour des quantités en stock"
        parent="menu_laplatine_root"
        action="raw_material_stock_update_wizard_action"
        sequence="20"
    />

    <menuitem
        id="menu_procurement_control_root"
        name="Pilotage approvisionnements"
        parent="stock.menu_stock_config_settings"
        sequence="25"
        groups="laplatine_procurement_control.group_procurement_control_user"
    />
    <menuitem
        id="menu_procurement_control_cockpit"
        name="Cockpit"
        parent="menu_procurement_control_root"
        action="procurement_control_line_action"
        sequence="10"
    />
</odoo>
